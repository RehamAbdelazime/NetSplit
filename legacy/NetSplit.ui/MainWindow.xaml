<Window x:Class="NetSplit.ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetSplit - Debug" Height="420" Width="640">
    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top"
                   Text="Running Network Processes"
                   FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>

        <DataGrid x:Name="ProcessGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  ItemsSource="{Binding}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Process Name" Binding="{Binding ProcessName}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="80" IsReadOnly="True"/>
                <DataGridTextColumn Header="Current Adapter" Binding="{Binding CurrentAdapter}" Width="140" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="Route Through" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox SelectedItem="{Binding SelectedAdapter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Loaded="AdapterComboBox_Loaded"
                                      SelectionChanged="AdapterComboBox_SelectionChanged"
                                      Tag="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
