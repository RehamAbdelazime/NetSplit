<Window x:Class="NetSplit.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:NetSplit.App.Converters"
        Title="NetSplit" Height="640" Width="820">
    <Window.Resources>
        <conv:BoolToExpandGlyphConverter x:Key="ExpandGlyph"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <DockPanel Margin="12">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
            <TextBlock Text="NetSplit" FontSize="20" FontWeight="Bold" HorizontalAlignment="Left"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ValidationButton" Content="Validation (dev)" Padding="8,2" Margin="0,0,8,0" Click="ValidationButton_Click"/>
                <Button x:Name="DiagnosticsButton" Content="Diagnostics (dev)" Padding="8,2" Click="DiagnosticsButton_Click"/>
            </StackPanel>
        </Grid>
        <Rectangle DockPanel.Dock="Top" Height="1" Fill="Gray" Margin="0,0,0,8"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Processes}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="0,8">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="200"/>
                                    </Grid.ColumnDefinitions>

                                    <ToggleButton Grid.Column="0" Width="22" Margin="0,0,6,0"
                                                  IsChecked="{Binding IsExpanded}"
                                                  Content="{Binding IsExpanded, Converter={StaticResource ExpandGlyph}}"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ProcessName}" FontWeight="Bold"/>
                                        <TextBlock Foreground="Gray" FontSize="11">
                                            <Run Text="PID "/><Run Text="{Binding Pid, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="12,0" MinWidth="90" VerticalAlignment="Center">
                                        <TextBlock Text="Current" FontSize="10" Foreground="Gray"/>
                                        <TextBlock Text="{Binding CurrentAdapter}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" Margin="12,0" MinWidth="130" VerticalAlignment="Center">
                                        <TextBlock Text="Send / Receive" FontSize="10" Foreground="Gray"/>
                                        <TextBlock>
                                            <Run Text="{Binding SendRateText, Mode=OneWay}"/>
                                            <Run Text=" / "/>
                                            <Run Text="{Binding ReceiveRateText, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <ComboBox Grid.Column="4" VerticalAlignment="Center"
                                              ItemsSource="{Binding AdapterOptions}"
                                              SelectedItem="{Binding SelectedAdapterOption, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="2">
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Ipv4Text}" FontSize="10" Foreground="Gray"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding Connections}"
                                              Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}"
                                              Margin="28,8,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40"/>
                                                    <ColumnDefinition Width="170"/>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="170"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="TCP" FontSize="11" Foreground="Gray"/>
                                                <TextBlock Grid.Column="1" Text="{Binding LocalEndpoint}" FontSize="11" FontFamily="Consolas"/>
                                                <TextBlock Grid.Column="2" Text="→" FontSize="11" HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="3" Text="{Binding RemoteEndpoint}" FontSize="11" FontFamily="Consolas"/>
                                                <TextBlock Grid.Column="4" Text="{Binding Adapter}" FontSize="11"/>
                                                <TextBlock Grid.Column="5" Text="{Binding State}" FontSize="11" Foreground="Gray"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
