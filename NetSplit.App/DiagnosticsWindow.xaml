<Window x:Class="NetSplit.App.DiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetSplit Diagnostics (developer)" Height="720" Width="900"
        FontFamily="Consolas" FontSize="12">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Pipeline trace: chrome.exe -&gt; PID -&gt; Runtime Rule -&gt; IOCTL -&gt; Kernel Cache -&gt; Classify() -&gt; Rewrite -&gt; Permit"
                       FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock x:Name="LastRefreshedText" Margin="20,0,0,0" Foreground="Gray" VerticalAlignment="Center"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <TextBlock Text="DEVICE OPEN PROOF (why DriverConnected is what it is)" FontWeight="Bold" FontSize="14" Margin="0,4"/>
                <ItemsControl x:Name="DeviceOpenFields"/>

                <TextBlock Text="SERVICE" FontWeight="Bold" FontSize="14" Margin="0,12,0,4"/>
                <ItemsControl x:Name="ServiceFields"/>

                <TextBlock Text="DRIVER" FontWeight="Bold" FontSize="14" Margin="0,12,0,4"/>
                <ItemsControl x:Name="DriverFields"/>

                <TextBlock Text="RUNTIME RULES (permanent rule -&gt; PID -&gt; pushed address)" FontWeight="Bold" FontSize="14" Margin="0,12,0,4"/>
                <ItemsControl x:Name="RuntimeRulesList"/>

                <TextBlock Text="ADAPTER CACHE" FontWeight="Bold" FontSize="14" Margin="0,12,0,4"/>
                <ItemsControl x:Name="AdapterCacheList"/>

                <TextBlock Text="PERMANENT RULES" FontWeight="Bold" FontSize="14" Margin="0,12,0,4"/>
                <ItemsControl x:Name="PermanentRulesList"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
